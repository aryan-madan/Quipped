{
  "manifest_version": 3,
  "name": "Quipped",
  "version": "0.1.0",
  "description": "Type shortcodes and expand them anywhere on the web.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Quipped",
    "default_popup": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
