{
  "name": "quipped",
  "version": "1.0.0",
  "description": "Type shortcodes and emojis anywhere on the web.",
  "main": "index.js",
  "type": "commonjs",
  "license": "ISC",
  "author": "",
  "keywords": [],
  "scripts": {
    "build": "node scripts/build.mjs",
    "postinstall": "node scripts/merge.mjs",
    "package:chrome": "cd dist/chrome && zip -r ../quipped-chrome.zip . -x '.*' && cd ../..",
    "package:firefox": "cd dist/firefox && zip -r ../quipped-firefox.zip . -x '.*' && cd ../..",
    "package": "npm run package:chrome && npm run package:firefox"
  },
  "dependencies": {
    "emojilib": "^4.0.3",
    "unicode-emoji-json": "^0.9.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
